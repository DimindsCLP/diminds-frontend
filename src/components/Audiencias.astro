<section class="audiences" id="audiencias">
  <div class="audiences__inner">
    <div class="audiences__header">
      <h2>
        Organizaciones que enfrentan desafíos complejos.
      </h2>
    </div>

    <div class="audiences__grid">
      <article class="audience-card">
        <h3>Instituciones financieras</h3>
        <p class="audience-card__description">
          Cooperativas, IFNB y cajas de compensación en proceso
          de transformación o regulación CMF.
        </p>
        <span class="audience-card__label">Qué buscan</span>
        <p class="audience-card__need">
          Criterio ejecutivo para tomar decisiones estructurales
          sin contratar un ejecutivo a tiempo completo.
        </p>
      </article>

      <article class="audience-card">
        <h3>Empresas medianas</h3>
        <p class="audience-card__description">
          Organizaciones de 20 a 300 colaboradores en crecimiento
          acelerado o transformación cultural y organizacional.
        </p>
        <span class="audience-card__label">Qué buscan</span>
        <p class="audience-card__need">
          Acompañamiento para alinear equipos, fortalecer liderazgo
          y sostener el cambio.
        </p>
      </article>

      <article class="audience-card">
        <h3>Organismos institucionales</h3>
        <p class="audience-card__description">
          Programas multilaterales y proyectos de asistencia técnica
          (BID · CORFO · CAF).
        </p>
        <span class="audience-card__label">Qué buscan</span>
        <p class="audience-card__need">
          Consultores con ejecución comprobada en terreno — no solo metodología.
        </p>
      </article>
    </div>
  </div>
</section>
